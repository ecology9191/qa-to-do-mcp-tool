{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QA-To-Do",
  "version": "0.1.1",
  "identifier": "dev.sandcastle.qa-to-do",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QA To Do",
        "width": 1040,
        "height": 720,
        "minWidth": 360,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local-first QA checklist for Sandcastle/RALPH output",
    "longDescription": "QA To Do is a local-first Linux desktop checklist for human QA of completed Sandcastle/RALPH work. It imports validated MCP inbox sessions and keeps QA evidence local.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "section": "devel",
        "priority": "optional"
      }
    }
  }
}
