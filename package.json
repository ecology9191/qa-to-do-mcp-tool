{
  "name": "qa-to-do",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "bin": {
    "qa-to-do": "./dist-node/qa-to-do.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:mcp": "node scripts/build-mcp.mjs",
    "sync:version": "node scripts/sync-tauri-version.mjs",
    "tauri": "tauri",
    "prepackage:linux": "npm run sync:version",
    "package:linux": "tauri build --bundles deb,appimage",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck:sandcastle": "tsc -p ./tsconfig.sandcastle.json --noEmit",
    "test": "vitest run",
    "secrets:scan": "gitleaks detect --source . --verbose"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tauri-apps/api": "^2.0.0",
    "svelte": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ecology91/sandcastle": "^0.5.14",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/svelte": "^5.2.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "jsdom": "^25.0.0",
    "svelte-check": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
