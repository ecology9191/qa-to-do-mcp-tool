{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QA To Do",
  "version": "0.1.0",
  "identifier": "dev.sandcastle.qa-to-do",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QA To Do",
        "width": 1040,
        "height": 720,
        "minWidth": 360,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "category": "DeveloperTool",
    "shortDescription": "Local-first QA checklist for Sandcastle/RALPH output"
  }
}
